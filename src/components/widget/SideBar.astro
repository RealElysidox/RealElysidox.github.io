---
import { DEFAULT_LANG, type Lang } from '../../i18n/langs'
import Categories from './Categories.astro'
import Profile from './Profile.astro'
import Tag from './Tags.astro'

interface Props {
  class?: string
  lang?: Lang
}

const className = Astro.props.class
const lang: Lang = Astro.props.lang ?? DEFAULT_LANG
---
<div id="sidebar" class:list={[className, "w-full"]}>
    <div class="flex flex-col w-full gap-4 mb-4">
        <Profile lang={lang}></Profile>
    </div>
    <div class="flex flex-col w-full gap-4 top-4 sticky top-4">
        <Categories lang={lang} class="onload-animation" style="animation-delay: 150ms"></Categories>
        <Tag lang={lang} class="onload-animation" style="animation-delay: 200ms"></Tag>
    </div>
</div>
